# Required for the digital twin API (server only — never exposed to the browser).
OPENROUTER_API_KEY=

# If the site uses next.config `basePath`, set the same value here so the chat client calls the correct API URL.
# NEXT_PUBLIC_BASE_PATH=

# Canonical site URL for OpenRouter HTTP-Referer, Open Graph metadata, and metadataBase.
# Prefer this over NEXT_PUBLIC_* when the value is server-only (not needed in the browser bundle).
SITE_URL=http://localhost:3000

# Legacy: still read as fallback if SITE_URL is unset (may be inlined in client bundle at build time).
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: override the chat model without redeploying code (default: openai/gpt-oss-20b).
# DIGITAL_TWIN_MODEL=openai/gpt-oss-20b

# Rate limits (in-memory per Node process). On serverless, each instance has its own memory —
# limits are best-effort only; use Redis/Upstash/Vercel KV for shared quotas in production.
# DIGITAL_TWIN_RL_MAX=30
# DIGITAL_TWIN_RL_WINDOW_MS=900000
# DIGITAL_TWIN_RL_SESSION_MAX=60

# PII note: email and phone in app/content/profile.ts are shipped to the browser for this portfolio.
# Use the digital twin for sensitive follow-up if you want to reduce public scraping exposure.
