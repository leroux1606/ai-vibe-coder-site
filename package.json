{
	"name": "ai-vibe-coder-site",
	"version": "0.1.0",
	"private": true,
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"dev": "node scripts/kill-port.mjs && next dev -p 3000",
		"dev:ipv4": "node scripts/kill-port.mjs && node --dns-result-order=ipv4first ./node_modules/next/dist/bin/next dev -p 3000",
		"build": "next build",
		"start": "next start -p 3000",
		"test": "tsx --test \"scripts/**/*.test.ts\"",
		"lint": "tsc --noEmit",
		"format": "prettier --write \"app/**/*.{ts,tsx,css}\" \"scripts/**/*.ts\" middleware.ts",
		"format:check": "prettier --check \"app/**/*.{ts,tsx,css}\" \"scripts/**/*.ts\" middleware.ts"
	},
	"dependencies": {
		"next": "^16.2.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"prettier": "^3.8.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
